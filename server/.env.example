# 复制为 .env 并填好。.env 不要提交。

# SQLite 数据文件（一个文件搞定；备份就是拷这个文件）
DB_FILE=./data/zfsi.db

# 进入 App 的 PIN（服务端校验；和前端锁屏用同一个）
APP_PIN=1234
# 给 token 签名用的随机串，自己改一个长的
AUTH_SECRET=change-me-to-a-long-random-string

# OpenRouter：一个 key 覆盖 判定 / 生成 / STT / TTS
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxx
MODEL_JUDGE=anthropic/claude-3.5-haiku
MODEL_GENERATE=anthropic/claude-3.5-sonnet
MODEL_STT=openai/whisper-large-v3-turbo
MODEL_TTS=openai/gpt-4o-mini-tts
TTS_VOICE=alloy

# 服务端口 & 允许的前端来源（CORS）
PORT=8787
CORS_ORIGIN=*
